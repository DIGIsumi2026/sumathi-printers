# =========================
# Dependencies
# =========================
node_modules/
frontend/node_modules/
backend/node_modules/

# Package manager cache/store
.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Keep lock files tracked
!package-lock.json
!pnpm-lock.yaml
!yarn.lock


# =========================
# Build outputs
# =========================
dist/
build/
frontend/dist/
frontend/build/
backend/dist/


# =========================
# Vite / tooling cache
# =========================
.vite/
frontend/.vite/
frontend/node_modules/.vite/
.cache/
.parcel-cache/
.turbo/


# =========================
# Environment files
# =========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

backend/.env
backend/.env.local
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local

# Keep example env files tracked
!.env.example
!frontend/.env.example
!backend/.env.example


# =========================
# Backend runtime data
# The current backend saves contact / quote / newsletter data here.
# Do not commit real customer inquiries.
# =========================
backend/data/*.json
!backend/data/.gitkeep


# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*


# =========================
# TypeScript
# =========================
*.tsbuildinfo


# =========================
# Testing / coverage
# =========================
coverage/
.nyc_output/


# =========================
# OS files
# =========================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini


# =========================
# Editor / IDE files
# =========================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# =========================
# Local archives / generated packages
# =========================
*.zip
*.rar
*.7z
*.tar
*.tar.gz


# =========================
# Local database files
# Not currently used, but safe if Prisma/SQLite is added again later.
# =========================
*.db
*.db-journal
*.sqlite
*.sqlite3
backend/prisma/dev.db
backend/prisma/dev.db-journal


# =========================
# Temporary files
# =========================
tmp/
temp/
*.tmp
*.temp